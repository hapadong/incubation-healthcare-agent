# HealthAgent Configuration
# Copy this file to .env and fill in your values
# .env is gitignored — never commit real credentials

# ── Model Endpoint ────────────────────────────────────────────────────────────
# Choose ONE of the sections below

# Option A: Azure OpenAI
HEALTHAGENT_API_BASE_URL=https://YOUR-RESOURCE.openai.azure.com
HEALTHAGENT_API_KEY=your-azure-api-key-here
HEALTHAGENT_MODEL=gpt-4o
# HEALTHAGENT_AZURE_DEPLOYMENT=your-deployment-name   # if different from model
# HEALTHAGENT_AZURE_API_VERSION=2025-01-01-preview    # default, change if needed

# Option B: Local Ollama
# HEALTHAGENT_API_BASE_URL=http://localhost:11434/v1
# HEALTHAGENT_API_KEY=local
# HEALTHAGENT_MODEL=llama3.1:70b

# Option C: Local vLLM
# HEALTHAGENT_API_BASE_URL=http://localhost:8000/v1
# HEALTHAGENT_API_KEY=local
# HEALTHAGENT_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# Option D: Standard Anthropic API (no HEALTHAGENT_ vars needed, use original)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Optional Settings ─────────────────────────────────────────────────────────
# HEALTHAGENT_AZURE_API_VERSION=2025-01-01-preview
