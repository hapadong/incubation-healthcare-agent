# HealthAgent Configuration
# Copy this file to .env and fill in your values
# .env is gitignored — never commit real credentials

# ── Model Endpoint ────────────────────────────────────────────────────────────
# Choose ONE of the sections below

# Option A: Azure OpenAI
HEALTHAGENT_API_BASE_URL=https://YOUR-RESOURCE.openai.azure.com
HEALTHAGENT_API_KEY=your-azure-api-key-here
HEALTHAGENT_MODEL=gpt-4o
# HEALTHAGENT_AZURE_DEPLOYMENT=your-deployment-name   # if different from model
# HEALTHAGENT_AZURE_API_VERSION=2025-01-01-preview    # default, change if needed

# Option B: Local Ollama
# HEALTHAGENT_API_BASE_URL=http://localhost:11434/v1
# HEALTHAGENT_API_KEY=local
# HEALTHAGENT_MODEL=llama3.1:70b

# Option C: Local vLLM / MLX (oMLX, vLLM, LM Studio, etc.)
# HEALTHAGENT_API_BASE_URL=http://localhost:8000/v1
# HEALTHAGENT_API_KEY=your-local-api-key
# HEALTHAGENT_MODEL=mlx-community/gemma-4-26b-a4b-it-4bit
# HEALTHAGENT_MAX_CONTEXT_TOKENS=32768   # set to your model's actual context window
# HEALTHAGENT_MAX_OUTPUT_TOKENS=4096     # IMPORTANT for 32k models: prevents constant
#                                        # auto-compact (default 32k output reservation
#                                        # leaves zero input headroom on a 32k window)

# Option D: Standard Anthropic API (no HEALTHAGENT_ vars needed, use original)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Clinical MCP Servers ──────────────────────────────────────────────────────
# NCBI API key — free at https://www.ncbi.nlm.nih.gov/account/
# Without key: 3 req/s. With key: 10 req/s.
# NCBI_API_KEY=your-ncbi-api-key-here

# OpenFDA API key — free at https://open.fda.gov/apis/authentication/
# Without key: 240 req/hour. With key: 1000 req/min.
# OPENFDA_API_KEY=your-openfda-api-key-here

# MIMIC-IV BigQuery — GCP project with MIMIC-IV dataset access
# Only needed if you use the mimic__* MCP tools.
# MIMIC_GCP_PROJECT=your-gcp-project-id

# ── PHI Guardrail ─────────────────────────────────────────────────────────────
# MCP tools listed here bypass the PHI output scanner (they are treated as
# internal/trusted — e.g. curated scientific databases where queries are
# de-identified by the model before being sent).
# HEALTHAGENT_INTERNAL_TOOLS=pubmed__pubmed_search,pubmed__pubmed_fetch,pubmed__pubmed_related,trials__trials_search,trials__trial_detail,drugs__drug_lookup,drugs__drug_adverse_events,drugs__drug_recalls,drugs__drug_rxnorm,coding__icd10_search,coding__loinc_search,guidelines__guidelines_search,guidelines__health_topic,mimic__mimic_patient,mimic__mimic_labs,mimic__mimic_cohort,mimic__mimic_icu,mimic__mimic_sql,patients__patient_list,patients__patient_load,patients__patient_save,patients__patient_update,patients__patient_generate_id

# ── Web Search ────────────────────────────────────────────────────────────────
# Provider: brave (default) or tavily
# Brave:  get free key at https://brave.com/search/api  (2000 queries/month free)
# Tavily: get free key at https://tavily.com            (1000 queries/month free)
# HEALTHAGENT_SEARCH_PROVIDER=brave
# HEALTHAGENT_SEARCH_API_KEY=your-search-api-key-here

# ── Optional Features ─────────────────────────────────────────────────────────
# Enable multi-agent swarms (experimental)
# HEALTHAGENT_ENABLE_SWARMS=true
