{
  "mcpServers": {
    "pubmed": {
      "command": "node",
      "args": ["mcp/pubmed/index.js"],
      "env": {
        "NCBI_API_KEY": "${NCBI_API_KEY}"
      }
    },
    "trials": {
      "command": "node",
      "args": ["mcp/trials/index.js"]
    },
    "coding": {
      "command": "node",
      "args": ["mcp/coding/index.js"]
    },
    "drugs": {
      "command": "node",
      "args": ["mcp/drugs/index.js"],
      "env": {
        "OPENFDA_API_KEY": "${OPENFDA_API_KEY}"
      }
    },
    "guidelines": {
      "command": "node",
      "args": ["mcp/guidelines/index.js"],
      "env": {
        "NCBI_API_KEY": "${NCBI_API_KEY}"
      }
    }
  }
}
